IDR_DESKMENU MENU DISCARDABLE 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Cascade browsers",            IDM_CASCADE
        MENUITEM "Arrange task icons",          IDM_ARRANGE
        MENUITEM "Line up icons",               IDM_LINEUP
        MENUITEM "Close browsers",              IDM_CLOSEALL
        MENUITEM "Clear desktop",               IDM_CLEAR
        MENUITEM SEPARATOR
        MENUITEM "Properties...",               IDM_DESKPROP
        MENUITEM "About...",                    IDM_ABOUT
    END
END

IDR_ICONMENU MENU DISCARDABLE 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Open",                       IDM_OBJ_OPEN
        MENUITEM "Open &with",                  IDM_OBJ_OPENWITH
        MENUITEM "&Inspect",                    IDM_OBJ_INSPECT
        MENUITEM SEPARATOR
