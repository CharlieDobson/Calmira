        MENUITEM "&Copy",                       IDM_OBJ_COPY
        MENUITEM "&Paste",                      IDM_OBJ_PASTE
        MENUITEM SEPARATOR
        MENUITEM "&Delete",                     IDM_OBJ_DELETE
        MENUITEM "Re&name",                     IDM_OBJ_RENAME
        MENUITEM "Descri&be",                   IDM_OBJ_DESCRIBE
        MENUITEM "Edit alia&s",                 IDM_OBJ_EDITALIAS
        MENUITEM "D&uplicate",                  IDM_OBJ_DUPLICATE
        MENUITEM SEPARATOR
        MENUITEM "P&roperties",                 IDM_OBJ_PROP
    END
END

IDR_WINMENU MENU DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open\tEnter",                IDM_OBJ_OPEN
        MENUITEM "Open &with...",               IDM_OBJ_OPENWITH
        MENUITEM "&Inspect",                    IDM_OBJ_INSPECT
        MENUITEM SEPARATOR
        MENUITEM "&Create folder...",           IDM_WIN_MKDIR
        MENUITEM "Create &alias...",            IDM_WIN_ALIAS
        MENUITEM SEPARATOR
        MENUITEM "&Close",                      IDM_CLOSE
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "Cu&t\tCtrl+X",                IDM_OBJ_CUT
        MENUITEM "&Copy\tCtrl+C",               IDM_OBJ_COPY
        MENUITEM "&Paste\tCtrl+V",              IDM_OBJ_PASTE
        MENUITEM SEPARATOR
        MENUITEM "&Delete\tDel",                IDM_OBJ_DELETE
        MENUITEM "Re&name\tF2",                 IDM_OBJ_RENAME
        MENUITEM "Descri&be",                   IDM_OBJ_DESCRIBE
        MENUITEM "D&uplicate",                  IDM_OBJ_DUPLICATE
        MENUITEM SEPARATOR
        MENUITEM "Select &all\tCtrl+A",         IDM_SELALL
        MENUITEM "I&nvert selection",           IDM_SELINV
        MENUITEM SEPARATOR
        MENUITEM "P&roperties\tAlt+Enter",      IDM_OBJ_PROP
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Lar&ge icons",                IDM_VIEW_LARGE
        MENUITEM "S&mall icons",                IDM_VIEW_SMALL
        MENUITEM "&Details",                    IDM_VIEW_DETAILS
        MENUITEM SEPARATOR
        MENUITEM "Sort by &Name",               IDM_SORT_NAME
        MENUITEM "Sort by &Type",               IDM_SORT_TYPE
        MENUITEM "Sort by &Size",               IDM_SORT_SIZE
        MENUITEM "Sort by &Date",               IDM_SORT_DATE
        MENUITEM SEPARATOR
        MENUITEM "Set &filter...",              IDM_FILTER
        MENUITEM "File s&ystem...",             IDM_FILESYS
        MENUITEM SEPARATOR
        MENUITEM "Show &hidden files",          IDM_SHOWHIDDEN
        MENUITEM "&Refresh\tF5",                IDM_REFRESH
    END
    POPUP "&Network"
    BEGIN
        MENUITEM "Map network &drive...",       IDM_NETCONN
        MENUITEM "&Disconnect...",              IDM_NETDISCONN
    END
END

